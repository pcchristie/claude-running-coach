# .env — Running Coach Skill Configuration
# Fill in your own values.
# Never commit your actual .env to version control.

# ── Athlete IDs ────────────────────────────────────────────────────────────────
# Find your Intervals.icu athlete ID in your profile URL: intervals.icu/athlete/iXXXXXX
# If coaching others, add their IDs here (they must nominate you as coach in Intervals.icu)
#
# Name each athlete however you like -- whatever comes after ATHLETE_ID_ becomes
# the --athlete flag value for sync.py. Add as many as you need.
# Examples:
#   ATHLETE_ID_ME=iXXXXXX
#   ATHLETE_ID_ALEX=iYYYYYY
#   ATHLETE_ID_SAM=iZZZZZZ
# ...etc

ATHLETE_ID_ATHLETE1=iXXXXXX
ATHLETE_ID_ATHLETE2=iYYYYYY
ATHLETE_ID_ATHLETE3=iZZZZZZ   # etc -- add or remove as many as you need

# ── API Key ────────────────────────────────────────────────────────────────────
# Your Intervals.icu API key. Found in Settings → API.
# Coach access: your key works for all athletes who have nominated you as coach.

API_KEY=your_api_key_here

# ── Default athlete ────────────────────────────────────────────────────────────
# Used by the Intervals.icu MCP when athlete_id is not passed explicitly.
# Set to your own athlete ID as a safe fallback.

ATHLETE_ID=iXXXXXX